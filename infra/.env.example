# Caddy — set to your domain for automatic HTTPS
# OSMSG_DOMAIN=stats.example.com

# Worker — leave blank for planet/minute defaults
# OSMSG_NAME=nepal
# OSMSG_URL=minute           # minute/hour/day or full URL; ignored when OSMSG_COUNTRY is set
# OSMSG_COUNTRY=nepal
# OSMSG_BOOTSTRAP=day
# OSMSG_BOOTSTRAP_DAYS=      # exact day count; alternative to OSMSG_BOOTSTRAP
# OSMSG_BOUNDARY=            # GeoJSON path or Geofabrik region name; overrides OSMSG_COUNTRY geometry
# OSMSG_SCHEDULE=0 * * * *
# OSM_USERNAME=
# OSM_PASSWORD=
