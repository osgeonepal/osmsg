DATABASE_URL=postgresql://osmsg:osmsg@localhost:5432/osmsg

# Worker (docker compose) — leave blank for planet/minute defaults.
# OSMSG_NAME=nepal
# OSMSG_URL=minute           # minute/hour/day or full URL; ignored when OSMSG_COUNTRY is set
# OSMSG_COUNTRY=nepal
# OSMSG_BOOTSTRAP=day
# OSMSG_BOOTSTRAP_DAYS=      # alternative to OSMSG_BOOTSTRAP for arbitrary day counts
# OSMSG_BOUNDARY=            # path to GeoJSON; overrides auto-derived country geometry
# OSMSG_SCHEDULE=0 * * * *
# OSM_USERNAME=
# OSM_PASSWORD=
